rules_version = '2';

// ============================================================================
// HOW TO USE THIS FILE
// ----------------------------------------------------------------------------
// This repo has NO server, so nothing here gets deployed automatically when
// you push to GitHub or Vercel. You must paste this into:
//
//   Firebase Console -> your project -> Firestore Database -> Rules tab
//   -> replace everything there with this file's contents -> Publish
//
// Without this (or something equivalent), your Firestore is either wide open
// (if you started in "test mode") or fully locked (if you started in
// "production mode" with the default deny-all rules) — either way, the admin
// panel and/or the storefront will misbehave until real rules are in place.
//
// ASSUMPTION THIS FILE MAKES: there is exactly one admin account, created by
// you directly in Firebase Console -> Authentication -> Users (email +
// password). Customers never sign in — checkout is guest-only. So "is this
// request from the admin?" is simply "is there ANY signed-in user?". If you
// ever add more admin accounts or customer logins, tighten `isAdmin()` to
// check a custom claim or an explicit allow-list instead.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null;
    }

    // Product catalog — anyone can read (that's how the storefront works
    // without a server), only the logged-in admin can write.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories & brands — same pattern.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons — the storefront (cart/checkout) must be able to read these
    // without logging in to validate a code at checkout; only the admin
    // panel can create/edit/delete them.
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Store settings (UPI id, support contact, EmailJS/ImgBB keys) — every
    // page needs to READ this without logging in, but only the admin panel
    // may write it.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — guests can CREATE an order (that's checkout, and checkout
    // never logs in), but only the admin can read the order list, view any
    // single order's details, update status, or delete anything. Without
    // this, either guests couldn't check out at all, or (worse) anyone could
    // read every customer's name/phone/address by guessing the collection.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Reviews — anyone can read (that's how they show up on product.html
    // for every visitor, not just the device that wrote them) and anyone
    // can create one (guest checkout site, no customer accounts to gate
    // this behind). A few basic shape checks are enforced here since this
    // is a public write: rating must be a whole number 1-5, comment can't
    // be a huge wall of text, and the client can't forge createdAt in the
    // past/future to game any "recent reviews" sorting.
    // Only the admin can edit or delete a review (e.g. to remove spam).
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.rating is int
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() <= 1000
                    && request.resource.data.productId is string;
      allow update, delete: if isAdmin();
    }

    // Telegram bot configs — UNLIKE every other collection above, this is
    // NOT public-read. A Telegram bot token is a real secret: whoever has
    // it can send messages as your bot into any chat/group it's in, and
    // potentially reconfigure or hijack it. So only the signed-in admin
    // can read or write this collection from the browser (Admin Panel).
    //
    // The serverless functions that actually SEND Telegram messages
    // (api/place-order.js, api/telegram-notify.js, api/cron-daily-digest.js)
    // do NOT read this collection through these rules at all — they use
    // the Firebase Admin SDK with a service account, which bypasses
    // Firestore rules entirely by design. That's what the service account
    // setup step is for. See SERVICE-ACCOUNT-SETUP-GUIDE.md.
    match /telegram_bots/{botId} {
      allow read, write: if isAdmin();
    }
  }
}
